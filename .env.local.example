ANTHROPIC_API_KEY=your-anthropic-api-key-here
CALENDLY_API_KEY=your-calendly-personal-access-token-here

# Stripe (Shop checkout)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TEST_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_TEST_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_AFTER_WEBHOOK_SETUP

# Resend (order notification + customer confirmation emails)
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY

# Microsoft Clarity — analytics + session recording (production only)
# Set this in Vercel project settings → Environment Variables (Production scope).
# Layout guards on NODE_ENV === "production" + presence of this var, so leaving
# it unset locally / on previews disables Clarity automatically.
NEXT_PUBLIC_CLARITY_PROJECT_ID=xf9si2ousa
